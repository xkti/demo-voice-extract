+// Unlike a `ParseSendTable` embedded in the initial dem_datatables block (which
+// relies on prop_count/props being fully decoded to find its end), an inline
+// svc_SendTable message is self-delimiting: a 1-bit needs_decoder flag is
+// followed by a 16-bit bit-length of the remaining payload, so it can be
+// skipped without understanding the send-prop encoding at all.
+fn skip_send_table(stream: &mut Stream) -> Result<()> {
+    let _needs_decoder: bool = stream.read()?;
+    let length: u16 = stream.read()?;
+    stream.skip_bits(length as usize)?;
+    Ok(())
+}
